# Copie este arquivo para .env e ajuste conforme seu ambiente.

# Provider do modelo: "gemini" (cloud, rápido) ou "ollama" (local).
MODEL_PROVIDER=gemini

# --- Gemini API (Google AI Studio) — pegue sua chave em https://aistudio.google.com/apikey ---
GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-flash-latest

# --- Ollama local (usado se MODEL_PROVIDER=ollama) ---
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_HOST=http://localhost:11434

# --- Persistência (SQLite do Agno) ---
AGENT_DB_FILE=agent_sessions.db

# --- Parâmetros do agente ---
AGENT_NAME=OSINT Recon Agent
NUM_HISTORY_RUNS=5

# --- Servidor Flask ---
# Obs: NAO definir FLASK_HOST aqui — no Docker o Dockerfile usa 0.0.0.0.
# Local, o default do codigo (127.0.0.1) ja funciona.
FLASK_PORT=5000
